# Supabase — copy to .env.local
# Use the Project URL from Dashboard → Settings → API (no /rest/v1/ suffix)
# Production runtime requires Supabase configuration (no demo fallback).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Required for password reset and auth redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never expose to the browser (admin agent APIs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
